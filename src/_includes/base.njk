<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('Simple Data Table') }}</title>
    <style>
        :root {
            --primary: #4a6fa5;
            --light: #f8f9fa;
            --dark: #343a40;
            --border: #dee2e6;
            --hover: #f1f3f5;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: #333;
            padding: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        h1 {
            color: var(--primary);
            margin-bottom: 1.5rem;
            font-weight: 600;
        }
        
        .table-container {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            margin: 1.5rem 0;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
            font-size: 0.85em;
        }
        
        /* Sugar column header text visibility */
        .mobile-text {
            display: none;
        }
        
        @media (max-width: 768px) {
            .desktop-text {
                display: none;
            }
            
            .mobile-text {
                display: inline;
            }
            
            .table-container {
                font-size: 0.75em;
                margin: 1rem 0;
            }
            
            table {
                width: 100%;
                table-layout: fixed;
            }
            
            th, td {
                padding: 0.3rem 0.4rem;
                word-wrap: break-word;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            
            th:first-child, td:first-child {
                width: 15%;
            }
            
            th:nth-child(2), td:nth-child(2) {
                width: 45%;
            }
            
            /* Sugar column - fit content on mobile */
            th:nth-child(3), td:nth-child(3) {
                width: auto;
                min-width: 60px;
                text-align: center;
                white-space: nowrap;
            }
            
            th:last-child {
                width: 15%;
                min-width: 80px;
                max-width: 100px;
                font-size: 0.75em;
                white-space: normal;
                word-break: break-word;
                line-height: 1.2;
                padding: 0.3rem 0.2rem;
            }
            
            td:last-child {
                width: 15%;
                min-width: 80px;
                max-width: 100px;
                font-family: monospace;
                font-size: 0.8em;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.95rem;
        }
        
        th, td {
            padding: 0.6rem 0.8rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
            line-height: 1.4;
        }
        
        th {
            background-color: #f8f9fa;
            position: sticky;
            top: 0;
            cursor: pointer;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            padding: 0.6rem 0.8rem;
            font-weight: 500;
            font-size: 0.9em;
        }
        
        /* Add a wrapper for header content */
        th > span {
            display: inline-block;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
            vertical-align: middle;
        }
        
        /* Style for EAN column */
        th:last-child > span {
            max-width: 100%;
            text-align: center;
            display: block;
            width: 100%;
        }
        
        /* Center EAN column content */
        td:last-child {
            text-align: center;
            padding: 0.6rem 0.2rem;
        }
        
        /* Center the barcode button */
        .barcode-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            padding: 0;
            background: none;
            border: none;
            cursor: pointer;
        }
        
        /* Sort arrow styling */
        th::after {
            content: '';
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            width: 1rem;
            height: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9em;
            opacity: 0.3;
            transition: opacity 0.2s;
        }
        
        th:hover::after {
            opacity: 0.7;
        }
        
        th.sort-asc::after,
        th.sort-desc::after {
            opacity: 1;
        }
        
        th.sort-asc::after {
            content: '↑';
        }
        
        th.sort-desc::after {
            content: '↓';
        }
        
        tr:hover {
            background-color: var(--hover);
        }
        
        tr:last-child td {
            border-bottom: none;
        }
        
        @media (max-width: 768px) {
            body {
                padding: 1rem;
            }
            
            th, td {
                padding: 0.3rem 0.4rem;
                font-size: 0.9rem;
            }
        }
    </style>
    <style>
        /* Barcode Modal */
        .barcode-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        
        .barcode-modal-content {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            text-align: center;
            max-width: 90%;
            max-height: 90%;
            overflow: auto;
        }
        
        .barcode-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #333;
        }
        
        .barcode-btn:hover {
            color: #0066cc;
        }
        
        #barcode-canvas {
            max-width: 100%;
            height: auto;
            margin: 1rem 0;
        }
        
        .close-btn {
            background: #f44336;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            margin-top: 1rem;
        }
        
        .close-btn:hover {
            background: #d32f2f;
        }
    </style>
</head>
<body>
    {% block content %}{% endblock %}
    
    {{ content | safe }}
    <script src="js/table-manager.js"></script>
    <!-- Barcode Modal -->
    <div id="barcodeModal" class="barcode-modal">
        <div class="barcode-modal-content">
            <h3>Code-barres EAN-13</h3>
            <div id="barcode-container">
                <canvas id="barcode-canvas"></canvas>
            </div>
            <p id="barcode-number"></p>
            <button class="close-btn">Fermer</button>
        </div>
    </div>
    
    <!-- JsBarcode Library -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    
    <!-- Barcode Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('barcodeModal');
            const closeBtn = document.querySelector('.close-btn');
            const barcodeNumber = document.getElementById('barcode-number');
            
            // Handle barcode button clicks
            document.querySelectorAll('.barcode-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const ean = this.getAttribute('data-ean');
                    if (ean) {
                        showBarcode(ean);
                    }
                });
            });
            
            // Close modal when clicking the close button
            closeBtn.addEventListener('click', function() {
                modal.style.display = 'none';
            });
            
            // Close modal when clicking outside the content
            window.addEventListener('click', function(event) {
                if (event.target === modal) {
                    modal.style.display = 'none';
                }
            });
            
            function showBarcode(ean) {
                try {
                    // Format EAN to ensure it's 13 digits
                    const formattedEan = ean.padStart(13, '0').substring(0, 13);
                    
                    // Clear previous barcode
                    const canvas = document.getElementById('barcode-canvas');
                    const ctx = canvas.getContext('2d');
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    
                    // Generate new barcode
                    JsBarcode("#barcode-canvas", formattedEan, {
                        format: "EAN13",
                        lineColor: "#000",
                        width: 2,
                        height: 80,
                        displayValue: true,
                        fontSize: 16,
                        margin: 10
                    });
                    
                    // Update barcode number display
                    barcodeNumber.textContent = formattedEan;
                    
                    // Show modal
                    modal.style.display = 'flex';
                } catch (error) {
                    console.error('Error generating barcode:', error);
                    alert('Erreur lors de la génération du code-barres');
                }
            }
        });
    </script>
</body>
</html>
